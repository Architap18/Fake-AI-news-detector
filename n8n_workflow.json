        "jsCode": "// UNIVERSAL NORMALIZER\nconst searchData = $node[\"Google Search — Verify Live News\"]?.json || {};\nconst formInput = $node[\"Trigger — New Form Submission\"]?.json || {};\nconst backlogInput = $node[\"Manual — Fetch 100 Backlog Articles\"]?.json || {};\nconst webInput = $node[\"Webhook — Website (Web Search)\"]?.json || {};\n\nconst headline = webInput.headline || formInput[\"News Article Headline\"] || backlogInput[\"ARTICLE TITLE\"] || \"\";\nconst text = webInput.article_text || formInput[\"Article Text or URL...\"] || backlogInput[\"ARTICLE CONTENT\"] || headline;\n\nreturn { \n  headline, \n  text, \n  search_results: searchData.snippets || \"No live search data found\",\n  is_backlog: !!backlogInput[\"ARTICLE TITLE\"],\n  row_number: backlogInput.row_number || formInput.row_number\n};"
