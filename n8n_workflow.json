      "name": "Groq — AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [3250, 1200]
    },
    {
      "parameters": {
        "jsCode": "const ai = JSON.parse($node[\"Groq — AI Analysis\"].json.choices[0].message.content);\nconst source = ($node[\"Code — RAG Matcher\"].json.orig_source || \"\").toUpperCase();\nlet verdict = ai.verdict;\nlet rule = \"AI Cloud Intelligence\";\n\nif (source.includes('FABRICATED')) { verdict = 'FAKE'; rule = 'Rule 1: Blacklisted Source'; }\nelse if (ai.confidence > 80) { rule = 'Rule 2: High Confidence AI'; }\n\nreturn { ...ai, verdict, rule_applied: rule };"
      },
