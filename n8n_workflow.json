    {
      "parameters": {
        "jsCode": "// UNIVERSAL RAG MATCHER (Website + Google Form)\nconst inputData = $node[\"Webhook — Master Input\"].json;\n\n// Normalize data from Website OR Apps Script\nconst headline = inputData.headline || (inputData[\"News Article Headline\"] ? inputData[\"News Article Headline\"][0] : \"\");\nconst article_text = inputData.article_text || (inputData[\"Article Text or URL...\"] ? inputData[\"Article Text or URL...\"][0] : headline);\nconst source_name = inputData.source || (inputData[\"Source / Publication Name\"] ? inputData[\"Source / Publication Name\"][0] : \"Unknown\");\n\nconst kb = items.map(i => i.json);\nconst input = (headline || article_text).toLowerCase();\n\n// Similarity Match\nconst matches = kb.map(a => {\n  const title = (a[\"Source Name\"] || a.title || \"\").toLowerCase();\n  const score = input.split(' ').filter(word => title.includes(word) && word.length > 4).length;\n  return { ...a, similarity_score: score };\n}).sort((a, b) => b.similarity_score - a.similarity_score);\n\nreturn matches.slice(0, 3).map(m => ({\n  json: {\n    ...m,\n    orig_headline: headline,\n    orig_text: article_text,\n    orig_source: source_name\n  }\n}));"
      },
